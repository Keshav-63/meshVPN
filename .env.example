# Copy this file to .env and fill in your values.
# Do not commit real secrets.

# Named tunnel token from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-token

# Base domain used by deployed app hostnames.
# Example: if APP_BASE_DOMAIN=keshavstack.tech then apps resolve as <subdomain>.keshavstack.tech
APP_BASE_DOMAIN=keshavstack.tech

# Postgres connection string (use one of DATABASE_URL or SUPABASE_DB_URL).
# Supabase Postgres example:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
SUPABASE_DB_URL=

# Supabase JWT secret from Project Settings -> API -> JWT Settings.
SUPABASE_JWT_SECRET=

# Phase 1 backend behavior settings.
REQUIRE_AUTH=true
WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=3

# Phase 2 runtime backend settings.
# docker  -> legacy docker runtime
# k3s     -> kubernetes runtime through kubectl
RUNTIME_BACKEND=docker

# Enable worker CPU HPA apply behavior.
ENABLE_CPU_HPA=false

# Kubernetes settings for k3s backend.
K8S_NAMESPACE=meshvpn-apps
K8S_CONFIG_PATH=/root/.kube/config
# Host path to your kubeconfig directory (used as a bind mount into control-plane container).
# Set this to your WSL user kube dir, for example: /home/<your-user>/.kube
K8S_HOST_KUBE_DIR=/home/<your-user>/.kube
# Host path to your Docker config directory that contains ghcr login credentials.
# Set this to your WSL user docker config dir, for example: /home/<your-user>/.docker
K8S_HOST_DOCKER_CONFIG_DIR=/home/<your-user>/.docker
KUBECTL_BIN=kubectl

# Registry prefix used by k3s backend image push.
# Example: ghcr.io/your-org
K8S_IMAGE_PREFIX=
