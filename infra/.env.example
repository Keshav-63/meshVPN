# Copy this file to .env and fill in your values.
# Do not commit real secrets.

# Named tunnel token from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-token

# Base domain used by deployed app hostnames.
# Example: if APP_BASE_DOMAIN=keshavstack.tech then apps resolve as <subdomain>.keshavstack.tech
APP_BASE_DOMAIN=keshavstack.tech

# Postgres connection string (use one of DATABASE_URL or SUPABASE_DB_URL).
# Supabase Postgres example:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
SUPABASE_DB_URL=

# Supabase JWT secret from Project Settings -> API -> JWT Settings.
SUPABASE_JWT_SECRET=

# Phase 1 backend behavior settings.
REQUIRE_AUTH=true
WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=3
