# Copy this file to .env and fill in your values.
# Do not commit real secrets.

# Named tunnel token from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-token

# Base domain used by deployed app hostnames.
# Example: if APP_BASE_DOMAIN=keshavstack.tech then apps resolve as <subdomain>.keshavstack.tech
APP_BASE_DOMAIN=keshavstack.tech
